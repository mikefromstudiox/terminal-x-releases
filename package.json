{
  "name": "terminal-x",
  "version": "1.0.0",
  "description": "Terminal X - Car Wash POS System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,blue \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:react": "vite build",
    "build:protected": "vite build --mode production && electron-builder",
    "dist": "npm run build:react && electron-builder",
    "dist:win": "npm run build:react && electron-builder --win",
    "dist:mac": "npm run build:react && electron-builder --mac",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.terminalx.pos",
    "productName": "Terminal X",
    "copyright": "Copyright © 2024 Terminal X",
    "asar": true,
    "compression": "maximum",
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "terminal-x-releases"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Terminal X"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-by,spec}",
      "!**/node_modules/.bin"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    }
  }
}
