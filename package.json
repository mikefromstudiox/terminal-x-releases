{
  "name": "terminal-x",
  "version": "2.14.17",
  "private": true,
  "description": "Terminal X - POS System for Car Wash, Retail & Services",
  "author": "Studio X",
  "main": "electron/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,blue \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "dev:demo": "concurrently -k -n VITE,ELECTRON -c cyan,blue \"vite\" \"wait-on http://localhost:5173 && electron . --dev --user-data-dir=./.demo-userdata\"",
    "build:react": "vite build",
    "build:protected": "vite build --mode production && electron-builder",
    "dist": "npm run build:react && electron-builder && npm run verify:build",
    "dist:win": "npm run build:react && electron-builder --win && npm run verify:build",
    "verify:build": "node scripts/verify-asar.cjs && node scripts/smoke-test-build.cjs",
    "verify:asar": "node scripts/verify-asar.cjs",
    "smoke": "node scripts/smoke-test-build.cjs",
    "dist:win:beta": "npm run build:react && electron-builder --win -c.publish.channel=beta",
    "dist:mac": "npm run build:react && electron-builder --mac",
    "dist:mac:beta": "npm run build:react && electron-builder --mac -c.publish.channel=beta",
    "preview": "vite preview",
    "dev:web": "vite --config vite.web.config.mjs",
    "build:web": "vite build --config vite.web.config.mjs",
    "preview:web": "vite preview --config vite.web.config.mjs",
    "reset-db": "rm -f ~/Library/Application\\ Support/terminal-x/terminal-x.db"
  },
  "dependencies": {
    "@sentry/electron": "^7.11.0",
    "@sentry/react": "^10.49.0",
    "@vercel/speed-insights": "^2.0.0",
    "@xmldom/xmldom": "^0.8.12",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "better-sqlite3-multiple-ciphers": "^12.9.0",
    "dgii-ecf": "^1.8.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "idb": "^8.0.3",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.7.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "axios": "^1.15.0",
    "follow-redirects": "^1.15.12",
    "node-forge": "^1.4.0",
    "@xmldom/xmldom": "^0.8.12",
    "lodash": "^4.18.0",
    "minimatch": {
      "brace-expansion": "^5.0.2"
    },
    "brace-expansion": "^2.0.3",
    "picomatch": "^4.0.4",
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "com.terminalx.pos",
    "productName": "Terminal X",
    "copyright": "Copyright © 2024 Terminal X",
    "asar": true,
    "npmRebuild": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "maximum",
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "mikefromstudiox",
        "repo": "terminal-x-releases",
        "channel": "latest"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "Terminal.X-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Terminal X"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "db/**/*",
      "packages/services/sentry-scrub.cjs",
      "!**/*.map",
      "!**/*.{md,ts,d.ts}",
      "!**/node_modules/.bin/**",
      "!**/node_modules/*/{test,tests,__tests__,spec,specs,powered-by}/**",
      "!**/node_modules/*/{CHANGELOG,CHANGELOG.md,README,README.md,readme,readme.md,LICENSE,license}",
      "!**/node_modules/*/.{travis.yml,eslintrc,eslintrc.js,eslintrc.json,npmignore,editorconfig}",
      "!**/node_modules/better-sqlite3/deps/**",
      "!**/node_modules/better-sqlite3/src/**",
      "!**/node_modules/better-sqlite3/binding.gyp",
      "!**/node_modules/prebuild-install/**",
      "!**/node_modules/napi-build-utils/**",
      "!**/node_modules/node-abi/**",
      "!**/node_modules/detect-libc/**",
      "!**/node_modules/expand-template/**",
      "!**/node_modules/github-from-package/**"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    }
  }
}
