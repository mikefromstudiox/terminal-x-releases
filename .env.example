# Terminal X — environment variable template
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real keys.

# ── License ───────────────────────────────────────────────────────────────────
# Developer master key — grants full access before a real license is activated.
# Read by the Electron main process (no VITE_ prefix needed).
# Change this before distributing builds.
MASTER_LICENSE_KEY=TX-MASTER-2026

# URL of your deployed Terminal X License Server
# Development: http://localhost:5173
# Production:  https://your-server.railway.app
VITE_LICENSE_API=http://localhost:5173

# ── ef2.do (Dominican Republic e-CF fiscal API) ───────────────────────────────
# Token from https://ef2.do — leave blank to run in offline/stub mode.
# When blank the app falls back to legacy NCF (B01/B02) automatically.
EF2_TOKEN=

# ── Supabase (optional cloud sync / remote dashboard) ────────────────────────
# Leave both blank to disable cloud features. The app works fully offline.
SUPABASE_URL=
SUPABASE_ANON_KEY=
