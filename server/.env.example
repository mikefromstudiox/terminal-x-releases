# Terminal X License Server — Environment Variables
# Copy this file to .env and fill in the values

# Server port (Railway/Render set this automatically)
PORT=3000

# Admin API key — change this to a strong random string!
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=changeme-set-a-strong-random-key-here

# Path to the SQLite database file (default: ./licenses.db in server directory)
# DB_PATH=/data/licenses.db
