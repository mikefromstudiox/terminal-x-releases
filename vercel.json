{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --ignore-scripts --no-audit --no-fund",
  "buildCommand": "npm run build:web && node scripts/prepare-vercel.mjs && cd dist-web && npm install --silent --no-audit --no-fund",
  "outputDirectory": "dist-web",
  "framework": null,
  "git": { "deploymentEnabled": { "main": true } },
  "redirects": [
    { "source": "/demo/:vertical", "destination": "/", "permanent": true },
    { "source": "/demo-login", "destination": "/", "permanent": true },
    { "source": "/precios", "destination": "/pricing", "permanent": true },
    { "source": "/planes", "destination": "/pricing", "permanent": true },
    { "source": "/registro", "destination": "/signup", "permanent": true },
    { "source": "/industries", "destination": "/", "permanent": true },
    { "source": "/industries/:slug", "destination": "/industrias/:slug", "permanent": true },
    { "source": "/en/industries/invoicing",        "destination": "/en/industries/facturacion",   "permanent": true },
    { "source": "/en/industries/e-invoicing",      "destination": "/en/industries/facturacion",   "permanent": true },
    { "source": "/en/industries/dgii",             "destination": "/en/industries/facturacion",   "permanent": true },
    { "source": "/en/industries/retail",           "destination": "/en/industries/tiendas",       "permanent": true },
    { "source": "/en/industries/stores",           "destination": "/en/industries/tiendas",       "permanent": true },
    { "source": "/en/industries/restaurants",      "destination": "/en/industries/restaurantes",  "permanent": true },
    { "source": "/en/industries/auto-repair",      "destination": "/en/industries/mecanica",      "permanent": true },
    { "source": "/en/industries/mechanic",         "destination": "/en/industries/mecanica",      "permanent": true },
    { "source": "/en/industries/dealership",       "destination": "/en/industries/concesionario", "permanent": true },
    { "source": "/en/industries/auto-dealership",  "destination": "/en/industries/concesionario", "permanent": true },
    { "source": "/en/industries/loans",            "destination": "/en/industries/prestamos",     "permanent": true },
    { "source": "/en/industries/pawnshop",         "destination": "/en/industries/prestamos",     "permanent": true },
    { "source": "/en/industries/services",         "destination": "/en/industries/servicios",     "permanent": true },
    { "source": "/en/industries/payroll",          "destination": "/en/industries/empresas",      "permanent": true },
    { "source": "/en/industries/barber",           "destination": "/en/industries/salon",         "permanent": true }
  ],
  "rewrites": [
    { "source": "/fe/autenticacion/api/semilla", "destination": "/api/fe?action=semilla" },
    { "source": "/fe/autenticacion/api/ValidacionCertificado", "destination": "/api/fe?action=validarcertificado" },
    { "source": "/fe/autenticacion/api/validacioncertificado", "destination": "/api/fe?action=validarcertificado" },
    { "source": "/fe/recepcion/api/ecf", "destination": "/api/fe?action=recepcion" },
    { "source": "/fe/aprobacioncomercial/api/ecf", "destination": "/api/fe?action=aprobacion" },
    { "source": "/api/fe/:action", "destination": "/api/fe?action=:action" },
    { "source": "/blog/:slug", "destination": "/index.html" },
    { "source": "/((?!api/|fe/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'strict-dynamic' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.supabase.co https://www.google-analytics.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://www.google-analytics.com https://www.googletagmanager.com https://region1.google-analytics.com wss://localhost:8181 wss://localhost:8282 wss://localhost:8383 wss://localhost:8484 wss://localhost.qz.io:8181 wss://localhost.qz.io:8282 wss://localhost.qz.io:8383 wss://localhost.qz.io:8484 https://localhost.qz.io:8181 https://localhost.qz.io:8282 https://localhost.qz.io:8383 https://localhost.qz.io:8484; font-src 'self' data:; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        { "key": "Content-Type", "value": "image/png" },
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/digest/daily", "schedule": "0 13 * * *" },
    { "path": "/api/panel?action=cron_dgii_pull", "schedule": "0 7 * * *" },
    { "path": "/api/panel?action=anecf-drain", "schedule": "0 */6 * * *" },
    { "path": "/api/panel?action=cron_deploy_smoke", "schedule": "*/15 * * * *" },
    { "path": "/api/panel?action=cron_health_verifier", "schedule": "*/30 * * * *" }
  ]
}
